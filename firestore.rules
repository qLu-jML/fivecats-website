rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // email_signups: anyone can create (submit email), no one can read/update/delete from client
    match /email_signups/{document=**} {
      allow create: if request.resource.data.keys().hasAll(['email', 'timestamp', 'source'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 0
                    && request.resource.data.email.size() < 256
                    && request.resource.data.source is string;
      allow read, update, delete: if false;
    }

    // Default: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
